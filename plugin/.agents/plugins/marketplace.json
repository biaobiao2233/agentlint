{
  "name": "agentlint-local",
  "interface": {
    "displayName": "AgentLint Local"
  },
  "plugins": [
    {
      "name": "agentlint",
      "source": {
        "source": "local",
        "path": "./plugins/agentlint"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      },
      "category": "Developer Tools"
    }
  ]
}
